{
  "name": "git-it-got-it-good",
  "version": "1.0.0",
  "description": "Production-hardened Git Manager MCP server scaffold",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "validate:pinned": "node scripts/verify-pinned-deps.mjs"
  },
  "dependencies": {
    "@octokit/auth-app": "7.1.1",
    "@octokit/rest": "21.0.2",
    "express": "4.21.2",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.1",
    "@typescript-eslint/eslint-plugin": "8.16.0",
    "@typescript-eslint/parser": "8.16.0",
    "eslint": "9.16.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
